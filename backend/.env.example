# Base de datos - Supabase
# Obtené la URL en: supabase.com → tu proyecto → Settings → Database → Connection string → URI
# Usá el connection pooler (puerto 6543) para producción en Render:
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true"

# Para correr migraciones usá la URL directa (puerto 5432):
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

PORT=4000
NODE_ENV=development

JWT_SECRET="poné-algo-largo-y-random-acá"
JWT_EXPIRES_IN="2d"

FRONTEND_URL="http://localhost:5173"
